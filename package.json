{
  "name": "pi-devin-fusion",
  "version": "0.1.0",
  "description": "Devin sidekick planner/executor split for pi, inspired by opencode-fusion",
  "type": "module",
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/khanhdeptraivaicachuong/pi-devin-fusion.git"
  },
  "license": "MIT",
  "engines": {
    "node": ">=22.19.0"
  },
  "files": [
    "src/*.ts",
    "README.md",
    "LICENSE",
    "tsconfig.json"
  ],
  "scripts": {
    "clean": "rm -rf node_modules",
    "build": "echo 'pi-devin-fusion is loaded directly by pi via jiti; no build step required'",
    "check": "tsc --noEmit",
    "test": "node --import jiti/register src/__tests__/run.ts"
  },
  "pi": {
    "extensions": [
      "./src/index.ts"
    ]
  },
  "keywords": ["pi-package", "pi-extension", "devin", "fusion", "sidekick", "planner", "executor", "coding-agent", "llm"],
  "dependencies": {},
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*",
    "typebox": "*"
  },
  "devDependencies": {
    "jiti": "^2.4.0",
    "typescript": "^5.5.0"
  }
}
